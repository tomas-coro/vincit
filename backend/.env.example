# Vincit — variabili d'ambiente backend
# Copia in backend/.env per lo sviluppo locale. In produzione (Render)
# vanno impostate nel dashboard del servizio. Vedi anche render.yaml.

# ── Obbligatorie ───────────────────────────────────────────────────────
# Connessione Postgres (Neon in produzione)
DATABASE_URL=postgres://user:pass@host/dbname

# Segreto firma JWT — OBBLIGATORIO, il server non parte senza.
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# ── Server ─────────────────────────────────────────────────────────────
# PORT=3001
# NODE_ENV=development

# ── Admin ──────────────────────────────────────────────────────────────
# All'avvio promuove a admin l'utente con questa email (FUNZIONALE in prod:
# senza, nessun account admin esiste).
ADMIN_EMAIL=
# Chiave condivisa per la diagnostica /api/admin (opzionale)
ADMIN_KEY=

# ── Cloudinary (upload immagini/avatar) ────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Web Push (notifiche) ───────────────────────────────────────────────
# Genera le chiavi una volta sola: npx web-push generate-vapid-keys
VAPID_SUBJECT=mailto:you@example.com
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── Email / SMTP (reset password, inviti) ──────────────────────────────
# Opzionale: senza SMTP l'app funziona ma il reset password non invia mail.
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# URL base dell'app, usato nei link delle email (es. https://vincit-xq87.onrender.com)
APP_BASE_URL=

# ── Error tracking (opzionale) ─────────────────────────────────────────
SENTRY_DSN=

# ── CORS (opzionale) ───────────────────────────────────────────────────
# Origin extra separati da virgola; in prod l'URL Render è già incluso.
# ALLOWED_ORIGIN=
